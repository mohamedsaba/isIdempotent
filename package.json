{
  "name": "@nestjs-idempotency/core",
  "version": "1.0.0",
  "description": "Distributed idempotency protection for NestJS",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "lint": "eslint 'src/**/*.ts'",
